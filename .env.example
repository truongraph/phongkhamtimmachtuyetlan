# Sao chép thành .env (hoặc đặt trong Vercel > Settings > Environment Variables)
# Bỏ trống 3 dòng dưới => app chạy chế độ localStorage (chỉ trên máy bạn).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Slug của phòng khám cho bản deploy này (khớp companies.slug trong Supabase).
# 1 project Supabase có thể chứa nhiều phòng khám; mỗi bản deploy đặt 1 slug.
VITE_SITE_SLUG=tuyetlan
